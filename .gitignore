# .gitignore for the `modsync` Rust project
# This ignores build artifacts, editor/IDE files and common OS junk.

# Rust build output (ignore everything under `target/`)
# The trailing slash and recursive pattern ensure all files and subfolders
# are ignored. Keep this at the top so other rules can't accidentally
# re-include build artifacts.
target/
target/**

# Compiled library and binary artefacts
*.rlib
*.rmeta
*.dSYM/
*.so
*.dylib
*.dll
*.exe
*.pdb

# If you use `cargo test --nocapture` or other logs
*.log

# Editor directories and files
# (Keep editor project files in the repo so workspace settings and tasks can be shared.)
.idea/
*.iml

# Backup and temporary files
*~
*.swp
*.swo

# macOS
.DS_Store

# Windows
Thumbs.db

# Environment files
.env
.env.*

# Node/npm
node_modules/
dist/

# Coverage and profiling
coverage/
*.profdata
*.prof

# Misc
.cache/
.history/

temp/
temp/**